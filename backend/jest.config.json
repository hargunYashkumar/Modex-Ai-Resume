{
  "testEnvironment": "node",
  "testMatch": [
    "**/__tests__/**/*.test.js"
  ],
  "testTimeout": 20000,
  "coverageDirectory": "coverage",
  "collectCoverageFrom": [
    "src/**/*.js",
    "!src/utils/seed.js",
    "!src/__tests__/**"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 40,
      "functions": 50,
      "lines": 50,
      "statements": 50
    }
  },
  "verbose": true,
  "setupFilesAfterEnv": []
}
