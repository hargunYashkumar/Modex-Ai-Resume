# Client-side base URL for API calls.
# In production (separate Vercel frontend/backend projects), this MUST be the full backend URL.
# Example: https://modex-ai-resume-backend.vercel.app
VITE_API_URL=http://localhost:5000
# Backend target for the Vite proxy (development only)
VITE_API_TARGET=http://localhost:5000
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
